{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "ignore": [
    "dist/**",
    "dev-dist/**",
    "node_modules/**",
    ".lifeos-cache/**",
    "lifeos-agent-cli/**"
  ],
  "entry": [
    "index.html",
    "src/main.tsx",
    "src/App.tsx",
    "src/sw.ts",

    "api/**/*.ts",

    "supabase/functions/**/index.ts",
    "supabase/functions/**/deno.d.ts"
  ],
  "project": [
    "src/**/*.{ts,tsx}",
    "api/**/*.ts",
    "supabase/functions/**/*.{ts,tsx}"
  ]
}

