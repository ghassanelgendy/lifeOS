{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable", "WebWorker"],
    "module": "ESNext",
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "paths": {
      "@/*": ["./src/*"],
      "./*.platform": [
        "./src/*.pake",
        "./src/*.web",
        "./src/hooks/*.pake",
        "./src/hooks/*.web",
        "./src/components/*.pake",
        "./src/components/*.web",
        "./src/components/ui/*.pake",
        "./src/components/ui/*.web",
        "./src/components/dashboard/*.pake",
        "./src/components/dashboard/*.web",
        "./src/routes/*.pake",
        "./src/routes/*.web"
      ],
      "../*.platform": [
        "./src/*.pake",
        "./src/*.web",
        "./src/hooks/*.pake",
        "./src/hooks/*.web",
        "./src/components/*.pake",
        "./src/components/*.web",
        "./src/routes/*.pake",
        "./src/routes/*.web"
      ],
      "../../*.platform": [
        "./src/*.pake",
        "./src/*.web",
        "./src/hooks/*.pake",
        "./src/hooks/*.web",
        "./src/components/*.pake",
        "./src/components/*.web",
        "./src/routes/*.pake",
        "./src/routes/*.web"
      ]
    }
  },
  "include": ["src"],
  "exclude": ["src/db", "**/*.test.ts", "src/sw.ts"]
}
