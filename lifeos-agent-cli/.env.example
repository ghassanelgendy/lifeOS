# Required for Ollama (any model: 7B, 70B, 120B, etc.)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gpt-oss:120b
OLLAMA_API_KEY=
# Max tokens for model output; increase for large models (e.g. 2048–4096 for 120B)
OLLAMA_NUM_PREDICT=2048

# Your Obsidian vault folder (optional but recommended)
OBSIDIAN_VAULT_PATH=G:/Path/To/ObsidianVault

# Optional Supabase (lifeOS DB). If unset, VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY are used.
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# Use service_role key so the CLI can read rows when RLS is on (Project Settings → API → service_role secret). Keep secret.
# SUPABASE_SERVICE_ROLE_KEY=
# Leave empty to allow all tables; or set comma-separated list.
# SUPABASE_ALLOWED_TABLES=

# Cache path for local index data
CACHE_DIR=.lifeos-cache
