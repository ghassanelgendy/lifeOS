{
  "name": "lifeos-agent-cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "life": "dist/index.js"
  },
  "description": "Offline-first CLI agent for lifeOS + Obsidian notes using Ollama",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "index-notes": "tsx src/index.ts index-notes",
    "ask": "tsx src/index.ts ask"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.94.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.1",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
