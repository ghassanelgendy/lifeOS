# Supabase (Vite uses VITE_*; Vercel API routes can use same or SUPABASE_*)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Optional for server API routes: TickTick token storage and task calendar feeds
SUPABASE_SERVICE_ROLE_KEY=

# Push (optional)
VITE_VAPID_PUBLIC_KEY=

# TickTick – set in Vercel / local .env (client_id and redirect are client-safe; secret is server-only)
VITE_TICKTICK_CLIENT_ID=
VITE_TICKTICK_REDIRECT_URI=
TICKTICK_CLIENT_SECRET=
