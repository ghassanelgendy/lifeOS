# Supabase (Vite uses VITE_*; Vercel API routes should use server-side env vars)
SUPABASE_URL=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Optional for server API routes
SUPABASE_SERVICE_ROLE_KEY=
# Optional: public deployed origin used for calendar feed links in desktop/local builds
VITE_PUBLIC_APP_URL=

# Cron / reminder dispatch
CRON_SECRET=
# Optional per-job override; if set, api/cron/send-task-reminders.ts will use this too
TASKS_CRON_SECRET=
# Optional per-job override for Supabase habit reminder dispatch
HABITS_CRON_SECRET=

# Push (optional)
VITE_VAPID_PUBLIC_KEY=

