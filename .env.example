# Supabase (Vite uses VITE_*; Vercel API routes can use same or SUPABASE_*)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Optional for server API routes
SUPABASE_SERVICE_ROLE_KEY=
# Optional: public deployed origin used for calendar feed links in desktop/local builds
VITE_PUBLIC_APP_URL=

# Push (optional)
VITE_VAPID_PUBLIC_KEY=

