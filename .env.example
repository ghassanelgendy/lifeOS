# Supabase (required for tasks, habits, etc.)
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# Task reminder push notifications (optional). Generate keys with:
#   npx web-push generate-vapid-keys
# Then add the PUBLIC key here (keep the private key for Supabase Edge Function secrets).
# VITE_VAPID_PUBLIC_KEY=your_public_key_here
