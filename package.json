{
  "name": "lifeos-workspace",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "packageManager": "pnpm@10.18.0",
  "engines": {
    "node": ">=20.9.0",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "vite",
    "dev:ios": "vite --mode ios",
    "dev:pake": "vite --mode pake",
    "build": "vite build",
    "build:ios": "vite build --mode ios",
    "build:pake": "vite build --mode pake",
    "pake:local": "pnpm build:pake && pnpm exec pake dist/index.html --name \"lifeOS\" --icon public/icon-main.ico --hide-title-bar --show-system-tray --hide-on-close --inject scripts/pake-inject.js --iterative-build --use-local-file --debug && copy node_modules\\.pnpm\\pake-cli@3.13.0\\node_modules\\pake-cli\\src-tauri\\target\\x86_64-pc-windows-msvc\\debug\\pake-lifeos.exe lifeOS.exe",
    "lint": "eslint src",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "icons:apple": "node scripts/generate-apple-touch-icons.mjs"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.1",
    "@capacitor/core": "^8.4.2",
    "@capacitor/device": "^8.0.3",
    "@capacitor/dialog": "^8.0.1",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.4.2",
    "@capacitor/keyboard": "^8.0.5",
    "@capacitor/local-notifications": "^8.2.1",
    "@capacitor/network": "^8.0.1",
    "@capacitor/push-notifications": "^8.1.2",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.2",
    "@capacitor/status-bar": "^8.0.3",
    "@capawesome/capacitor-badge": "^8.0.2",
    "@capgo/capacitor-updater": "^8.51.2",
    "@fluentui/react-components": "^9.74.4",
    "@fluentui/react-icons": "^2.0.332",
    "@formkit/auto-animate": "^0.10.0",
    "@sqlite.org/sqlite-wasm": "^3.51.2-build6",
    "@supabase/supabase-js": "^2.110.8",
    "@tanstack/query-sync-storage-persister": "5.101.4",
    "@tanstack/react-query": "5.101.4",
    "@tanstack/react-query-persist-client": "5.101.4",
    "@types/marked": "^6.0.0",
    "@vercel/analytics": "^2.0.1",
    "adhan": "^4.4.4",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "framer-motion": "catalog:",
    "kysely": "^0.29.4",
    "lucide-react": "^1.26.0",
    "marked": "^18.0.7",
    "moment": "^2.30.1",
    "react": "19.2.8",
    "react-big-calendar": "^1.20.0",
    "react-dom": "19.2.8",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.10.0",
    "supabase": "^2.109.1",
    "supabase-cli": "^0.0.21",
    "tailwind-merge": "^3.6.0",
    "uuid": "^14.0.1",
    "vaul": "^1.1.2",
    "zod": "4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.2",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/adhan": "^4.0.4",
    "@types/node": "^26.1.1",
    "@types/pg": "8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-big-calendar": "^1.16.3",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "@vercel/node": "^5.8.26",
    "@vitejs/plugin-legacy": "^8.2.2",
    "@vitejs/plugin-react": "^6.0.4",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "pake-cli": "^3.15.3",
    "postcss": "^8.5.22",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.3",
    "typescript": "~7.0.2",
    "typescript-eslint": "^8.65.0",
    "vite": "^8.1.5",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10",
    "workbox-core": "^7.4.1",
    "workbox-precaching": "^7.4.1",
    "workbox-routing": "^7.4.1"
  },
  "pnpm": {
    "supportedArchitectures": {
      "os": [
        "current",
        "darwin",
        "linux",
        "win32"
      ],
      "cpu": [
        "current",
        "x64",
        "arm64"
      ]
    }
  }
}
